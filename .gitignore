# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/
*.spec

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Runtime data (user-specific, not shared)
settings.json
memory/sessions.json
outputs/*
!outputs/.gitkeep
config_hardware.json
install.log
cache/

# Network captures — may contain IPs, payloads, personal data
*.pcap
*.pcapng
*.cap
tcpdump*.txt
tcpdump*.log

# Generated launchers (created by installer, platform-specific)
Prompturgy
Prompturgy.bat

# Scratch / working files — never commit
f1.json
f2.json
scratch/
tmp/

# Test results — may contain user prompts / logs
tools/test_results*.json
tools/test_batch*.json

# Claude Code session data — local only
.claude/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Secrets / credentials
.env
.env.*
*.key
*.pem
credentials*
secrets*
*_secret*
id_rsa*
.netrc

*.zip
